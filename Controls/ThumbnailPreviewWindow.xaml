<Window x:Class="WindowPilot.Controls.ThumbnailPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ThumbnailPreview"
        Width="320" Height="220"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        Focusable="False">

    <Border BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Background="{StaticResource BgPrimary}">
        <Grid>
            <Grid.RowDefinitions>
                <!-- 标题区（36px）：图标 + 窗口标题 + 进程名 -->
                <RowDefinition Height="36" />
                <!-- 预览区：优先 DWM 合成，其次 PrintWindow 截图，最后占位提示 -->
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ── 标题区 ── -->
            <Border Grid.Row="0"
                    Background="{StaticResource BgTertiary}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="8,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Image x:Name="IconImage"
                           Grid.Column="0"
                           Width="16" Height="16"
                           VerticalAlignment="Center"
                           Margin="0,0,7,0"
                           RenderOptions.BitmapScalingMode="HighQuality" />

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="TitleTextBlock"
                                   Foreground="{StaticResource FgPrimary}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock x:Name="ProcessTextBlock"
                                   Foreground="{StaticResource FgSecondary}"
                                   FontSize="10"
                                   Margin="0,1,0,0"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── 预览区 ──
                 三层叠放（Z 序从低到高）：
                   1. 深色背景 (#0D0D14)
                   2. FallbackImage：PrintWindow 静态截图
                   3. FallbackPanel：截图也失败时的占位提示
                 DWM 注册成功时，DWM 合成层会在 WPF 渲染之上实时叠加，覆盖 FallbackImage。 -->
            <Grid Grid.Row="1" Background="#0D0D14">

                <!-- PrintWindow 截图（DWM 注册失败时作为回退显示） -->
                <Image x:Name="FallbackImage"
                       Stretch="Uniform"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Visibility="Collapsed"
                       RenderOptions.BitmapScalingMode="HighQuality" />

                <!-- 截图也失败时显示此占位面板 -->
                <StackPanel x:Name="FallbackPanel"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <TextBlock Text="⊞"
                               Foreground="{StaticResource FgSecondary}"
                               FontSize="36"
                               HorizontalAlignment="Center"
                               Opacity="0.35" />
                    <TextBlock x:Name="FallbackText"
                               Text="无法加载预览"
                               Foreground="{StaticResource FgSecondary}"
                               FontSize="11"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"
                               Opacity="0.45" />
                    <TextBlock x:Name="FallbackSubText"
                               Text="窗口无法被截图"
                               Foreground="{StaticResource FgSecondary}"
                               FontSize="9.5"
                               HorizontalAlignment="Center"
                               Margin="0,3,0,0"
                               Opacity="0.3" />
                </StackPanel>

            </Grid>
        </Grid>
    </Border>
</Window>
