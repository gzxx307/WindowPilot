<Window x:Class="WindowPilot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WindowPilot"
        Width="1200" Height="800"
        MinWidth="600" MinHeight="400"
        WindowState="Maximized"
        Background="{StaticResource BgPrimary}"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Loaded="MainWindow_Loaded"
        Closing="MainWindow_Closing"
        SizeChanged="MainWindow_SizeChanged">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- 工具栏 -->
            <RowDefinition Height="*"    />
            <!-- 主内容 -->
            <RowDefinition Height="Auto" />
            <!-- Debug 面板 -->
            <RowDefinition Height="Auto" />
            <!-- 状态栏 -->
        </Grid.RowDefinitions>

        <!-- ══ 工具栏 ══ -->
        <Border Grid.Row="0"
                Background="{StaticResource BgSecondary}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="◈" Foreground="{StaticResource AccentBrush}"
                               FontSize="18" VerticalAlignment="Center" Margin="4,0,8,0" />
                    <TextBlock Text="WindowPilot" Foreground="{StaticResource FgPrimary}"
                               FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"
                               Margin="0,0,20,0" />

                    <Button x:Name="BtnStacked" Content="▣ 堆叠"
                            Style="{StaticResource PilotButton}" Margin="2" FontSize="11.5"
                            Click="LayoutMode_Click" Tag="Stacked" />
                    <Button x:Name="BtnQuad" Content="⊞ 四分区"
                            Style="{StaticResource PilotButton}" Margin="2" FontSize="11.5"
                            Click="LayoutMode_Click" Tag="QuadSplit" />
                    <Button x:Name="BtnLeftRight" Content="◫ 左右"
                            Style="{StaticResource PilotButton}" Margin="2" FontSize="11.5"
                            Click="LayoutMode_Click" Tag="LeftRight" />
                    <Button x:Name="BtnTopBottom" Content="⬒ 上下"
                            Style="{StaticResource PilotButton}" Margin="2" FontSize="11.5"
                            Click="LayoutMode_Click" Tag="TopBottom" />

                    <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush}" Margin="8,0" />

                    <Button Content="↻ 重排"
                            Style="{StaticResource PilotButton}" Margin="2" FontSize="11.5"
                            Click="RefreshLayout_Click" />
                    <Button Content="✕ 全部释放"
                            Style="{StaticResource PilotButton}" Margin="2" FontSize="11.5"
                            Click="ReleaseAll_Click" />

                    <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush}" Margin="8,0" />

                    <Button x:Name="BtnDebug" Content="⚙ Debug"
                            Style="{StaticResource PilotButton}" Margin="2" FontSize="11.5"
                            Click="ToggleDebug_Click" />
                </StackPanel>

                <TextBlock Grid.Column="2" x:Name="WindowCountText"
                           Text="0 个窗口" Foreground="{StaticResource FgSecondary}"
                           FontSize="11.5" VerticalAlignment="Center" Margin="0,0,8,0" />
            </Grid>
        </Border>

        <!-- ══ 主内容：侧边栏 + 嵌入区域 ══ -->
        <Grid Grid.Row="1" x:Name="ContentGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="200" MinWidth="28" MaxWidth="360" />
                <ColumnDefinition x:Name="SplitterColumn" Width="4" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ── 侧边栏 ── -->
            <Border Grid.Column="0" x:Name="SidebarBorder"
                    Background="{StaticResource BgSecondary}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- 侧边栏标题 + 折叠按钮 -->
                    <Border Grid.Row="0"
                            Background="{StaticResource BgTertiary}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1" Padding="10,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="SidebarTitleText" Grid.Column="0"
                                       Text="管理的窗口"
                                       Foreground="{StaticResource FgSecondary}"
                                       FontSize="11" FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                            <Button x:Name="BtnToggleSidebar" Grid.Column="1"
                                    Content="◀" Width="22" Height="22"
                                    FontSize="10" Padding="0"
                                    Background="Transparent"
                                    Foreground="{StaticResource FgSecondary}"
                                    BorderThickness="0" Cursor="Hand"
                                    ToolTip="折叠侧边栏"
                                    Click="ToggleSidebar_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="bg" Background="Transparent" CornerRadius="3"
                                                            Width="{TemplateBinding Width}"
                                                            Height="{TemplateBinding Height}">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bg" Property="Background"
                                                                    Value="{StaticResource BgHover}" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- 侧边栏内容（含释放拖放区） -->
                    <Grid x:Name="SidebarContentPanel" Grid.Row="1">

                        <!-- 空状态提示 -->
                        <Border x:Name="EmptyStatePanel" Visibility="Visible">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="16">
                                <TextBlock Text="◇" Foreground="{StaticResource FgSecondary}"
                                           FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,10" />
                                <TextBlock Text="拖拽窗口到此侧边栏"
                                           Foreground="{StaticResource FgSecondary}"
                                           FontSize="12.5" HorizontalAlignment="Center"
                                           TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,6" />
                                <TextBlock Text="或按 Ctrl+Alt+G&#x0a;抓取当前活动窗口"
                                           Foreground="{StaticResource FgSecondary}"
                                           FontSize="11" HorizontalAlignment="Center"
                                           TextWrapping="Wrap" TextAlignment="Center" Opacity="0.6" />
                            </StackPanel>
                        </Border>

                        <!-- 窗口列表
                             条目支持拖拽：拖到其他条目 = 互换位置；拖到底部红色区域 = 释放托管 -->
                        <ListBox x:Name="WindowListBox"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 SelectionMode="Single" Visibility="Collapsed">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,1" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <!--
                                        拖拽操作说明：
                                        · PreviewMouseLeftButtonDown / PreviewMouseMove：启动 WPF 拖拽
                                        · DragOver / DragLeave / Drop：接收其他条目的拖放（互换位置）
                                        · MouseLeftButtonUp：无拖拽时触发点击切换
                                    -->
                                    <Border x:Name="ItemBorder"
                                            Padding="10,8"
                                            Background="Transparent"
                                            BorderThickness="2,0,0,0"
                                            BorderBrush="Transparent"
                                            Cursor="Hand"
                                            AllowDrop="True"
                                            MouseLeftButtonUp="WindowItem_Click"
                                            PreviewMouseLeftButtonDown="WindowItemBorder_PreviewMouseLeftButtonDown"
                                            PreviewMouseMove="WindowItemBorder_PreviewMouseMove"
                                            DragOver="WindowItemBorder_DragOver"
                                            DragLeave="WindowItemBorder_DragLeave"
                                            Drop="WindowItemBorder_Drop">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="28" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Image Grid.Column="0" Source="{Binding Icon}"
                                                   Width="20" Height="20"
                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                   VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}"
                                                           Foreground="{StaticResource FgPrimary}"
                                                           FontSize="12" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding ProcessName}"
                                                           Foreground="{StaticResource FgSecondary}"
                                                           FontSize="10" Margin="0,1,0,0" />
                                            </StackPanel>
                                            <Button Grid.Column="2" Content="✕"
                                                    Width="22" Height="22" FontSize="11"
                                                    Padding="0" Background="Transparent"
                                                    Foreground="{StaticResource FgSecondary}"
                                                    BorderThickness="0" Cursor="Hand"
                                                    VerticalAlignment="Center" ToolTip="释放窗口"
                                                    Tag="{Binding Handle}" Click="ReleaseButton_Click">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="bg" Background="Transparent"
                                                                            CornerRadius="3"
                                                                            Width="{TemplateBinding Width}"
                                                                            Height="{TemplateBinding Height}">
                                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                                          VerticalAlignment="Center" />
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="bg" Property="Background"
                                                                                    Value="#44F44747" />
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background"
                                                    Value="{StaticResource BgActive}" />
                                            <Setter TargetName="ItemBorder" Property="BorderBrush"
                                                    Value="{StaticResource AccentBrush}" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- ✨ 拖拽释放区：拖动侧边栏条目时出现，松手即解除托管 -->
                        <Border x:Name="SidebarReleaseZone"
                                VerticalAlignment="Bottom"
                                Height="52"
                                Background="#33F44747"
                                BorderBrush="{StaticResource FgError}"
                                BorderThickness="0,1,0,0"
                                AllowDrop="True"
                                Visibility="Collapsed"
                                Panel.ZIndex="10"
                                DragOver="SidebarReleaseZone_DragOver"
                                Drop="SidebarReleaseZone_Drop">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="✕" HorizontalAlignment="Center"
                                           Foreground="{StaticResource FgError}"
                                           FontSize="13" FontWeight="Bold" />
                                <TextBlock Text="拖至此处释放托管"
                                           Foreground="{StaticResource FgError}"
                                           FontSize="10" HorizontalAlignment="Center"
                                           Margin="0,3,0,0" />
                            </StackPanel>
                        </Border>

                    </Grid>
                </Grid>
            </Border>

            <!-- ── 分隔条 ── -->
            <GridSplitter Grid.Column="1" x:Name="MainSplitter"
                          Width="4" Background="{StaticResource BorderBrush}"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext" Cursor="SizeWE" />

            <!-- ── 嵌入宿主区域 ── -->
            <Border Grid.Column="2" x:Name="HostPanel"
                    Background="#1A1A1A" ClipToBounds="True"
                    SizeChanged="HostPanel_SizeChanged">
                <Border x:Name="DropHintPanel" Visibility="Visible">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="⊞" Foreground="{StaticResource FgSecondary}"
                                   FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,16" />
                        <TextBlock Text="窗口将在此处显示"
                                   Foreground="{StaticResource FgSecondary}"
                                   FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,6" />
                        <TextBlock Text="拖拽窗口到左侧侧边栏即可添加"
                                   Foreground="{StaticResource FgSecondary}"
                                   FontSize="12" HorizontalAlignment="Center" Opacity="0.5" />
                    </StackPanel>
                </Border>
            </Border>
        </Grid>

        <!-- ══ Debug 面板（默认隐藏） ══ -->
        <Border Grid.Row="2" x:Name="DebugPanel"
                Visibility="Collapsed"
                Background="#0A0A0A"
                BorderBrush="#3F3F46"
                BorderThickness="0,1,0,0"
                Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Text="DPI / 坐标系" Foreground="#569CD6"
                               FontSize="10" FontWeight="Bold" Margin="0,0,0,2"/>
                    <TextBlock x:Name="DbgDpiText"       FontSize="10" Foreground="#9CDCFE" Margin="0,1"/>
                    <TextBlock x:Name="DbgMousePhysText" FontSize="10" Foreground="#9CDCFE" Margin="0,1"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,16,0">
                    <TextBlock Text="DropZone（物理px）" Foreground="#569CD6"
                               FontSize="10" FontWeight="Bold" Margin="0,0,0,2"/>
                    <TextBlock x:Name="DbgDropZonePhysText" FontSize="10" Foreground="#9CDCFE" Margin="0,1"/>
                    <TextBlock x:Name="DbgMouseInZoneText"  FontSize="10" Foreground="#9CDCFE" Margin="0,1"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,16,0">
                    <TextBlock Text="Overlay 位置（DIP）" Foreground="#569CD6"
                               FontSize="10" FontWeight="Bold" Margin="0,0,0,2"/>
                    <TextBlock x:Name="DbgOverlayDipText" FontSize="10" Foreground="#9CDCFE" Margin="0,1"/>
                    <TextBlock x:Name="DbgSidebarPhysText" FontSize="10" Foreground="#9CDCFE" Margin="0,1"/>
                </StackPanel>

                <StackPanel Grid.Column="3">
                    <TextBlock Text="HostArea（客户区px）" Foreground="#569CD6"
                               FontSize="10" FontWeight="Bold" Margin="0,0,0,2"/>
                    <TextBlock x:Name="DbgHostAreaText"  FontSize="10" Foreground="#9CDCFE" Margin="0,1"/>
                    <TextBlock x:Name="DbgHostSizeText"  FontSize="10" Foreground="#9CDCFE" Margin="0,1"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ 状态栏 ══ -->
        <Border Grid.Row="3"
                Background="{StaticResource AccentBrush}" Padding="10,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Grid.Column="0"
                           Text="就绪" Foreground="White" FontSize="11"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="1"
                           Text="Ctrl+Alt+G 抓取 │ Ctrl+Alt+← → 切换 │ 侧边栏条目可拖拽排序"
                           Foreground="#BBFFFFFF" FontSize="10" VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</Window>
