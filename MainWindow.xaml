<Window x:Class="WindowPilot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="WindowPilot"
        Width="1200" Height="800"
        MinWidth="600" MinHeight="400"
        WindowState="Maximized"
        Background="{StaticResource BgPrimary}"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Loaded="MainWindow_Loaded"
        Closing="MainWindow_Closing"
        SizeChanged="MainWindow_SizeChanged">

    <Grid>
        <Grid.RowDefinitions>
            <!--
                Row 0: 工具栏（全宽，固定高度）。
                ToolbarWebView 在此行横跨全部 3 列，没有 HostPanel，无 airspace 冲突。
            -->
            <RowDefinition Height="42"/>
            <!--
                Row 1: 主内容（侧边栏 | 分隔条 | 嵌入宿主区域）。
                三者各占一列，互不重叠。
            -->
            <RowDefinition Height="*"/>
            <!--
                Row 2: 状态栏（全宽，固定高度）。
                StatusWebView 在此行横跨全部 3 列，没有 HostPanel，无 airspace 冲突。
            -->
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <!-- Col 0: 侧边栏 -->
            <ColumnDefinition x:Name="SidebarColumn" Width="200" MinWidth="28" MaxWidth="360"/>
            <!-- Col 1: GridSplitter（纯 WPF 元素，不含任何 HWND） -->
            <ColumnDefinition Width="4"/>
            <!-- Col 2: 嵌入宿主区域 -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ 工具栏 WebView2（Row 0，跨 3 列，全宽） ══════════════════ -->
        <wv2:WebView2 x:Name="ToolbarWebView"
                      Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                      DefaultBackgroundColor="#FF252526"/>

        <!-- ══ 侧边栏 WebView2（Row 1，Col 0） ═══════════════════════════ -->
        <!--
            SidebarBorder 保留 x:Name，供 UpdateDropZone() 通过 PointToScreen 计算坐标。
            SizeChanged 在 GridSplitter 拖动后触发。
        -->
        <Border x:Name="SidebarBorder"
                Grid.Row="1" Grid.Column="0"
                Background="#FF252526"
                SizeChanged="SidebarBorder_SizeChanged">
            <wv2:WebView2 x:Name="SidebarWebView"
                          DefaultBackgroundColor="#FF252526"/>
        </Border>

        <!-- ══ GridSplitter（Row 1，Col 1，纯 WPF） ══════════════════════ -->
        <GridSplitter Grid.Row="1" Grid.Column="1"
                      Width="4"
                      Background="#3F3F46"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      ResizeBehavior="PreviousAndNext"
                      Cursor="SizeWE"/>

        <!-- ══ 嵌入宿主区域（Row 1，Col 2，WPF HWND） ════════════════════ -->
        <Border Grid.Row="1" Grid.Column="2"
                x:Name="HostPanel"
                Background="#1A1A1A"
                ClipToBounds="True"
                SizeChanged="HostPanel_SizeChanged">
            <Border x:Name="DropHintPanel" Visibility="Visible">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="⊞" Foreground="{StaticResource FgSecondary}"
                               FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock Text="窗口将在此处显示"
                               Foreground="{StaticResource FgSecondary}"
                               FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock Text="拖拽窗口到左侧侧边栏即可添加"
                               Foreground="{StaticResource FgSecondary}"
                               FontSize="12" HorizontalAlignment="Center" Opacity="0.5"/>
                </StackPanel>
            </Border>
        </Border>

        <!-- ══ 状态栏 WebView2（Row 2，跨 3 列，全宽） ═══════════════════ -->
        <wv2:WebView2 x:Name="StatusWebView"
                      Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                      DefaultBackgroundColor="#FF007ACC"/>
    </Grid>
</Window>
