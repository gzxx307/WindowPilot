<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══ 核心色板 ══ -->
    <Color x:Key="BgPrimaryColor">#1E1E1E</Color>
    <Color x:Key="BgSecondaryColor">#252526</Color>
    <Color x:Key="BgTertiaryColor">#2D2D30</Color>
    <Color x:Key="BgHoverColor">#3E3E42</Color>
    <Color x:Key="BgSelectedColor">#094771</Color>
    <Color x:Key="BgActiveColor">#37373D</Color>

    <Color x:Key="BorderColor">#3F3F46</Color>
    <Color x:Key="BorderActiveColor">#007ACC</Color>

    <Color x:Key="FgPrimaryColor">#CCCCCC</Color>
    <Color x:Key="FgSecondaryColor">#969696</Color>
    <Color x:Key="FgAccentColor">#569CD6</Color>
    <Color x:Key="FgWarningColor">#CE9178</Color>
    <Color x:Key="FgSuccessColor">#6A9955</Color>
    <Color x:Key="FgErrorColor">#F44747</Color>

    <Color x:Key="AccentColor">#007ACC</Color>
    <Color x:Key="AccentHoverColor">#1C97EA</Color>

    <Color x:Key="DropZoneActiveColor">#33007ACC</Color>
    <Color x:Key="DropZoneBorderColor">#007ACC</Color>

    <!-- ══ 画笔 ══ -->
    <SolidColorBrush x:Key="BgPrimary" Color="{StaticResource BgPrimaryColor}" />
    <SolidColorBrush x:Key="BgSecondary" Color="{StaticResource BgSecondaryColor}" />
    <SolidColorBrush x:Key="BgTertiary" Color="{StaticResource BgTertiaryColor}" />
    <SolidColorBrush x:Key="BgHover" Color="{StaticResource BgHoverColor}" />
    <SolidColorBrush x:Key="BgSelected" Color="{StaticResource BgSelectedColor}" />
    <SolidColorBrush x:Key="BgActive" Color="{StaticResource BgActiveColor}" />

    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="BorderActiveBrush" Color="{StaticResource BorderActiveColor}" />

    <SolidColorBrush x:Key="FgPrimary" Color="{StaticResource FgPrimaryColor}" />
    <SolidColorBrush x:Key="FgSecondary" Color="{StaticResource FgSecondaryColor}" />
    <SolidColorBrush x:Key="FgAccent" Color="{StaticResource FgAccentColor}" />
    <SolidColorBrush x:Key="FgWarning" Color="{StaticResource FgWarningColor}" />
    <SolidColorBrush x:Key="FgSuccess" Color="{StaticResource FgSuccessColor}" />
    <SolidColorBrush x:Key="FgError" Color="{StaticResource FgErrorColor}" />

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />

    <SolidColorBrush x:Key="DropZoneActiveBrush" Color="{StaticResource DropZoneActiveColor}" />
    <SolidColorBrush x:Key="DropZoneBorderBrush" Color="{StaticResource DropZoneBorderColor}" />

    <!-- ══ 全局字体 ══ -->
    <FontFamily x:Key="DefaultFont">Segoe UI, Microsoft YaHei UI</FontFamily>
    <sys:Double x:Key="FontSizeSmall" xmlns:sys="clr-namespace:System;assembly=mscorlib">11</sys:Double>
    <sys:Double x:Key="FontSizeNormal" xmlns:sys="clr-namespace:System;assembly=mscorlib">13</sys:Double>
    <sys:Double x:Key="FontSizeLarge" xmlns:sys="clr-namespace:System;assembly=mscorlib">16</sys:Double>

    <!-- ══ Button 样式 ══ -->
    <Style x:Key="PilotButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BgTertiary}" />
        <Setter Property="Foreground" Value="{StaticResource FgPrimary}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="FontFamily" Value="{StaticResource DefaultFont}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeNormal}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource BgHover}" />
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BorderActiveBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource AccentBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource PilotButton}">
        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <!-- ══ ListBox / ListBoxItem ══ -->
    <Style x:Key="PilotListBox" TargetType="ListBox">
        <Setter Property="Background" Value="{StaticResource BgSecondary}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource FgPrimary}" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
    </Style>

    <Style x:Key="PilotListBoxItem" TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource FgPrimary}" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            BorderThickness="2,0,0,0"
                            BorderBrush="Transparent">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource BgHover}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource BgSelected}" />
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ══ TextBlock 默认 ══ -->
    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource DefaultFont}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeNormal}" />
        <Setter Property="Foreground" Value="{StaticResource FgPrimary}" />
    </Style>

    <!-- ══ ToolTip ══ -->
    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="{StaticResource BgTertiary}" />
        <Setter Property="Foreground" Value="{StaticResource FgPrimary}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource DefaultFont}" />
    </Style>

</ResourceDictionary>
